rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── families/{familyId} ───────────────────────────────────────────────────
    // Any authenticated user can read / write families documents.
    // The app itself enforces invite-code gating; the rule just requires auth.
    match /families/{familyId} {
      allow read, write: if request.auth != null;
    }

    // ── quests/{questId} ─────────────────────────────────────────────────────
    // quests belong to a family (familyId field). Any authenticated user may
    // read/write quests (the app enforces role-based UI restrictions).
    match /quests/{questId} {
      allow read, write: if request.auth != null;
    }

    // ── transactions/{txId} ──────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read, write: if request.auth != null;
    }

    // ── userFamilyMap/{userId} ───────────────────────────────────────────────
    match /userFamilyMap/{userId} {
      allow read, write: if request.auth != null;
    }

    // ── inviteCodes/{code} ───────────────────────────────────────────────────
    // Any authenticated user can read (to verify) and write (to mark as used).
    // Creation is restricted to systemAdmins at the app level.
    match /inviteCodes/{code} {
      allow read, write: if request.auth != null;
    }

    // ── systemAdmins/{uid} ───────────────────────────────────────────────────
    // Readable by any authenticated user (needed to check own admin status).
    // Write restricted to existing super admins — enforced at app level.
    match /systemAdmins/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── adventureConfig/{docId} ──────────────────────────────────────────────
    // Stores admin-managed adventure zone config (shop items, pet species,
    // expedition destinations, investment assets).
    // Read: any authenticated user (kids read when adventure zone is wired up).
    // Write: system admins only — enforced at app level.
    match /adventureConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
